# Optional local source overrides. Leave these commented on a fresh Mini PC
# after running script/bootstrap_sources.bash.
# AIRRADAR_SOURCE=./src/airradar
# LOCALIZATION_SOURCE=./src/airradar-localization
# ADSB2DD_SOURCE=./src/adsb2dd

TZ=America/Los_Angeles

# AirRadar API ports are configured in config/sensors/*/config.yml:
# sensor1: 3100
# sensor2: 3200
# sensor3: 3300

# Web ports exposed by this compose project.
SENSOR1_WEB_PORT=49161
SENSOR2_WEB_PORT=49162
SENSOR3_WEB_PORT=49163
LOCALIZATION_PORT=49256
TAR1090_PORT=8080
ADSB2DD_PORT=49155
