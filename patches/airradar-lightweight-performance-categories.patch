+function collectCategoryValuesLightweight(saveDir, config, request = {}) {
+  const allSessions = selectEvaluationSessions(saveDir, request);
+  const maxSessions = Math.max(1, Math.min(200, Number(request.maxCategorySessions) || 80));
+  const maxFramesPerSession = Math.max(1, Math.min(1000, Number(request.maxCategoryFramesPerSession) || 120));
+  const maxBytesPerSession = Math.max(64 * 1024, Math.min(4 * 1024 * 1024,
+    Number(request.maxCategoryBytesPerSession) || 512 * 1024));
+  const sessions = allSessions.slice(0, maxSessions);
+  const fields = createCategoryAccumulator();
+  let framesRead = 0;
+  let truncated = allSessions.length > sessions.length;
+
+  sessions.forEach((session) => {
+    const truthFile = getTruthFile(session);
+    if (!truthFile) {
+      return;
+    }
+    const sessionConfig = configForSession(session, config, request);
+    const { profile: sessionProfile } = normalizeProfile(sessionConfig, Object.assign({}, request, {
+      aircraftFilterField: '',
+      aircraftFilterValue: ''
+    }));
+    const frames = readRecentJsonLinesFile(truthFile.path, maxBytesPerSession)
+      .slice(-maxFramesPerSession);
+    if (frames.length >= maxFramesPerSession) {
+      truncated = true;
+    }
+    framesRead += frames.length;
+    frames.forEach((frame) => {
+      filterTruthAircraft(
+        normalizeAdsbAircraft({ aircraft: frame.aircraft || [] }),
+        sessionProfile,
+        { rx: frame.rx || {} }
+      ).forEach((aircraft) => {
+        addAircraftToCategoryAccumulator(fields, aircraft);
+      });
+    });
+  });
+
+  return categoryAccumulatorToResponse(fields, sessions, {
+    lightweight: true,
+    truncated,
+    totalSessions: allSessions.length,
+    sessionsScanned: sessions.length,
+    framesRead,
+    maxFramesPerSession,
+    maxBytesPerSession
+  });
 }
 
